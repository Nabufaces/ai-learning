{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "types": ["node"]
  },
  "include": [
    "evals/src/**/*.ts",
    "harness/**/*.ts",
    "labs/**/*.ts",
    "projects/**/*.ts"
  ],
  "exclude": ["node_modules", "dist", ".next"]
}

